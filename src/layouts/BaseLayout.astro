---
// Base layout: global styles, top navigation, footer.
// Modern, high-contrast look: zinc ink, indigo accent, dark terminal blocks.
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'WSL(Ubuntu) 설치 가이드' } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: base, label: '홈' },
  { href: `${base}/install/`, label: '새로 설치' },
  { href: `${base}/reinstall/`, label: '재설치' },
  { href: `${base}/troubleshooting/`, label: '문제 해결' },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href.replace(/\/+$/, '') || '/') === currentPath;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav aria-label="Main navigation">
        <a class="brand" href={base}>
          <span class="brand-mark"><Icon name="terminal" size={15} /></span>
          WSL 설치 가이드
        </a>
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>Python Ecosystem 2026 · WSL 설치 가이드</p>
      <p>스크린샷 출처: Microsoft Learn 문서 (CC BY 4.0) · 아이콘: Lucide</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Modern palette: zinc neutrals + indigo accent */
    --bg: #fafafa;
    --surface: #ffffff;
    --surface-muted: #f4f4f5;
    --ink: #18181b;
    --ink-soft: #52525b;
    --accent: #4f46e5;
    --accent-deep: #4338ca;
    --accent-soft: #eef2ff;
    --line: #e4e4e7;
    --code-bg: #f4f4f5;
    --radius: 12px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: 'Pretendard Variable', Pretendard, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 1.05rem;
    line-height: 1.8;
    word-break: keep-all;
  }

  header {
    background: rgb(255 255 255 / 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    max-width: 760px;
    margin: 0 auto;
    padding: 0.7rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  nav .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 8px;
    color: #fff;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
  }

  nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav ul a {
    display: block;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 500;
  }

  nav ul a:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  nav ul a[aria-current='page'] {
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-weight: 700;
  }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.2rem 4rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.35;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .page-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    margin-bottom: 0.9rem;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    box-shadow: 0 6px 16px rgb(99 102 241 / 0.35);
  }

  h2 {
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    margin: 2.5rem 0 0.8rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
  }

  h3 {
    font-size: 1.1rem;
    margin: 1.8rem 0 0.5rem;
  }

  a {
    color: var(--accent-deep);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  p {
    margin: 0.8rem 0;
  }

  .lead {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  code {
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: 0.9em;
    background: var(--code-bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.1em 0.4em;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.88rem;
    text-align: center;
    padding: 1.5rem 1.2rem 2.5rem;
  }

  footer p {
    margin: 0.3rem 0;
  }
</style>
