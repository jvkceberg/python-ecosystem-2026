---
// Base layout: global styles, top navigation, footer.
// Calm, low-saturation palette for comfortable long reading.
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'WSL(Ubuntu) 설치 가이드' } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: base, label: '홈' },
  { href: `${base}/install/`, label: '새로 설치' },
  { href: `${base}/reinstall/`, label: '재설치' },
  { href: `${base}/troubleshooting/`, label: '문제 해결' },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href.replace(/\/+$/, '') || '/') === currentPath;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav aria-label="Main navigation">
        <a class="brand" href={base}>🐧 WSL 설치 가이드</a>
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>Python Ecosystem 2026 · WSL 설치 가이드</p>
      <p>
        막히는 부분이 있으면 <a href={`${base}/troubleshooting/`}>문제 해결 페이지</a>를 먼저
        확인해 보세요.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Calm, low-saturation palette */
    --bg: #f7f6f3;
    --surface: #ffffff;
    --surface-muted: #efede8;
    --ink: #3d4045;
    --ink-soft: #6b7076;
    --accent: #7c8b9d; /* muted blue-grey */
    --accent-deep: #5a6b7d;
    --line: #e3e1db;
    --code-bg: #f0efec;
    --tip: #eef1ea;
    --tip-border: #aab7a0;
    --warn: #f5efe6;
    --warn-border: #c9b394;
    --info: #eaeef1;
    --info-border: #9fb0be;
    --radius: 10px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: 'Pretendard Variable', Pretendard, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 1.05rem;
    line-height: 1.8;
    word-break: keep-all;
  }

  header {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    max-width: 760px;
    margin: 0 auto;
    padding: 0.7rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  nav .brand {
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
  }

  nav ul {
    display: flex;
    gap: 0.3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav ul a {
    display: block;
    padding: 0.3rem 0.7rem;
    border-radius: 8px;
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
  }

  nav ul a:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  nav ul a[aria-current='page'] {
    background: var(--surface-muted);
    color: var(--accent-deep);
    font-weight: 600;
  }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.2rem 4rem;
  }

  h1 {
    font-size: 1.9rem;
    line-height: 1.4;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-size: 1.35rem;
    margin: 2.5rem 0 0.8rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line);
  }

  h3 {
    font-size: 1.1rem;
    margin: 1.8rem 0 0.5rem;
  }

  a {
    color: var(--accent-deep);
  }

  p {
    margin: 0.8rem 0;
  }

  .lead {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  code {
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: 0.92em;
    background: var(--code-bg);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.1em 0.4em;
  }

  kbd {
    font-family: inherit;
    font-size: 0.88em;
    background: var(--surface);
    border: 1px solid var(--line);
    border-bottom-width: 2px;
    border-radius: 5px;
    padding: 0.05em 0.45em;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.9rem;
    text-align: center;
    padding: 1.5rem 1.2rem 2.5rem;
  }

  footer p {
    margin: 0.3rem 0;
  }
</style>
