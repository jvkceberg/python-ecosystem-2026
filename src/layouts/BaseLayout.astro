---
// Base layout: global styles, top navigation with theme toggle, footer.
// Theme: light/dark via html[data-theme], initialized from localStorage or
// the OS preference before paint.
import Icon from '../components/Icon.astro';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Python 개발 생태계 입문 워크숍 자료와 환경 준비 안내' } =
  Astro.props;
const base = import.meta.env.BASE_URL;
const ogImage = new URL(`${base}/og-image.png?v=20260705.2`, Astro.site);

const navItems = [
  { href: `${base}/`, label: '홈' },
];
const wslItems = [
  { href: `${base}/wsl/`, label: '가이드 홈' },
  { href: `${base}/wsl/install/`, label: '새로 설치' },
  { href: `${base}/wsl/reinstall/`, label: '재설치' },
  { href: `${base}/wsl/troubleshooting/`, label: '문제 해결' },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  if (href.includes('#')) {
    return false;
  }
  const target = href.split('#')[0].replace(/\/+$/, '') || '/';
  if (target === (base.replace(/\/+$/, '') || '/')) {
    return currentPath === target;
  }
  return currentPath === target || currentPath.startsWith(`${target}/`);
};
const isExactActive = (href: string) => {
  const target = href.split('#')[0].replace(/\/+$/, '') || '/';
  return currentPath === target;
};
const isWslActive = currentPath.startsWith(`${base}/wsl`.replace(/\/+$/, ''));
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- Social share preview (Open Graph — used by KakaoTalk and others) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PYTHON ECOSYSTEM 2026" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono@5.2.5/index.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fontsource/ibm-plex-mono@5.2.5/index.css"
    />
    <title>{title}</title>
    <script is:inline>
      // Set the theme before first paint to avoid a flash of the wrong theme.
      const saved = localStorage.getItem('theme');
      const preferred = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = saved ?? preferred;
    </script>
  </head>
  <body>
    <header>
      <nav aria-label="Main navigation">
        <a class="brand" href={`${base}/`}>
          <span class="brand-mark"><Logo size={17} /></span>
          PYTHON ECOSYSTEM 2026
        </a>
        <div class="nav-right">
          <ul>
            {
              navItems.map((item) => (
                <li>
                  <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li class="nav-menu">
              <details>
                <summary aria-current={isWslActive ? 'page' : undefined}>WSL</summary>
                <div class="menu-panel">
                  {
                    wslItems.map((item) => (
                      <a
                        href={item.href}
                        aria-current={isExactActive(item.href) ? 'page' : undefined}
                      >
                        {item.label}
                      </a>
                    ))
                  }
                </div>
              </details>
            </li>
          </ul>
          <button type="button" class="theme-toggle" aria-label="Toggle color theme">
            <span class="ic-sun"><Icon name="sun" size={17} /></span>
            <span class="ic-moon"><Icon name="moon" size={17} /></span>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>PYTHON ECOSYSTEM 2026 · BEYOND THE START – FROM SCRIPTS TO PROJECTS</p>
      <p>스크린샷 출처: Microsoft Learn 문서 (CC BY 4.0) · 아이콘: Lucide</p>
    </footer>
  </body>
</html>

<script>
  // Theme toggle: flips html[data-theme] and remembers the choice.
  document.querySelector('.theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement;
    const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
    html.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

<style is:global>
  :root {
    /* Modern palette: zinc neutrals + indigo accent (light) */
    color-scheme: light;
    --bg: #fafafa;
    --surface: #ffffff;
    --surface-muted: #f4f4f5;
    --ink: #18181b;
    --ink-soft: #52525b;
    --accent: #4f46e5;
    --accent-deep: #4338ca;
    --accent-soft: #eef2ff;
    --line: #e4e4e7;
    --code-bg: #f4f4f5;
    --header-bg: rgb(255 255 255 / 0.85);
    --key-bg: linear-gradient(to bottom, #ffffff, #f4f4f5);
    --key-border: #d4d4d8;
    --tip-bg: #f0fdf4;
    --tip-border: #bbf7d0;
    --tip-ink: #15803d;
    --warn-bg: #fffbeb;
    --warn-border: #fde68a;
    --warn-ink: #b45309;
    --info-bg: #eff6ff;
    --info-border: #bfdbfe;
    --info-ink: #1d4ed8;
    --radius: 12px;
  }

  html[data-theme='dark'] {
    color-scheme: dark;
    --bg: #101013;
    --surface: #18181b;
    --surface-muted: #27272a;
    --ink: #e4e4e7;
    --ink-soft: #a1a1aa;
    --accent: #818cf8;
    --accent-deep: #a5b4fc;
    --accent-soft: rgb(99 102 241 / 0.18);
    --line: #27272a;
    --code-bg: #27272a;
    --header-bg: rgb(16 16 19 / 0.85);
    --key-bg: linear-gradient(to bottom, #3f3f46, #27272a);
    --key-border: #52525b;
    --tip-bg: rgb(16 185 129 / 0.09);
    --tip-border: rgb(16 185 129 / 0.35);
    --tip-ink: #34d399;
    --warn-bg: rgb(245 158 11 / 0.09);
    --warn-border: rgb(245 158 11 / 0.35);
    --warn-ink: #fbbf24;
    --info-bg: rgb(59 130 246 / 0.09);
    --info-border: rgb(59 130 246 / 0.35);
    --info-ink: #60a5fa;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: 'Pretendard Variable', Pretendard, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 1.05rem;
    line-height: 1.8;
    word-break: keep-all;
  }

  header {
    background: var(--header-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    max-width: 760px;
    margin: 0 auto;
    padding: 0.7rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  nav .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 8px;
    color: #fff;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
  }

  nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav ul a,
  nav summary {
    display: block;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 500;
  }

  nav summary {
    cursor: pointer;
    list-style: none;
  }

  nav summary::-webkit-details-marker {
    display: none;
  }

  nav summary::after {
    content: '';
    display: inline-block;
    width: 0.38rem;
    height: 0.38rem;
    margin-left: 0.35rem;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-0.12rem) rotate(45deg);
  }

  nav details[open] summary::after {
    transform: translateY(0.08rem) rotate(225deg);
  }

  nav ul a:hover,
  nav summary:hover {
    background: var(--surface-muted);
    color: var(--ink);
  }

  nav ul a[aria-current='page'],
  nav summary[aria-current='page'] {
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-weight: 700;
  }

  .nav-menu {
    position: relative;
  }

  .menu-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.45rem);
    z-index: 20;
    min-width: 10rem;
    padding: 0.35rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 12px 28px rgb(0 0 0 / 0.12);
  }

  .menu-panel a {
    border-radius: 8px;
    white-space: nowrap;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--ink-soft);
    cursor: pointer;
  }

  .theme-toggle:hover {
    color: var(--ink);
    background: var(--surface-muted);
  }

  .theme-toggle .ic-sun,
  .theme-toggle .ic-moon {
    display: none;
    line-height: 0;
  }

  html[data-theme='dark'] .theme-toggle .ic-sun {
    display: inline-flex;
  }

  html:not([data-theme='dark']) .theme-toggle .ic-moon {
    display: inline-flex;
  }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.2rem 4rem;
  }

  h1 {
    font-family: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-size: 2rem;
    line-height: 1.35;
    letter-spacing: 0;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-family: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-soft);
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.55;
    margin: 0 0 1.4rem;
  }

  .page-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    margin-bottom: 0.9rem;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    box-shadow: 0 6px 16px rgb(99 102 241 / 0.35);
  }

  h2 {
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    margin: 2.5rem 0 0.8rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
  }

  h3 {
    font-size: 1.1rem;
    margin: 1.8rem 0 0.5rem;
  }

  a {
    color: var(--accent-deep);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  p {
    margin: 0.8rem 0;
  }

  .lead {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  code {
    font-family: 'JetBrains Mono', ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: 0.88em;
    background: var(--code-bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.1em 0.4em;
  }

  /* Inline PowerShell app badge — used at the first mention of PowerShell */
  .ps-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.08em 0.55em 0.08em 0.4em;
    border-radius: 8px;
    background: linear-gradient(135deg, #5391fe, #2671be);
    color: #fff;
    font-weight: 700;
    font-size: 0.9em;
    white-space: nowrap;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.88rem;
    text-align: center;
    padding: 1.5rem 1.2rem 2.5rem;
  }

  footer p {
    margin: 0.3rem 0;
  }
</style>
