---
// PowerShell app logo: blue rounded tile with the white ">_" glyph.
interface Props {
  size?: number;
}

const { size = 16 } = Astro.props;
---

<span class="ps-logo" style={`--s: ${size}px`} aria-hidden="true">
  <svg
    width={size * 0.72}
    height={size * 0.72}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="3"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="m5 7 5 5-5 5"></path>
    <path d="M13 17h6"></path>
  </svg>
</span>

<style>
  .ps-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--s);
    height: var(--s);
    flex-shrink: 0;
    border-radius: 22%;
    background: linear-gradient(135deg, #5391fe, #2671be);
    color: #fff;
  }
</style>
