---
// Dark terminal-style command block with an icon-only copy button.
// PowerShell commands are branded with the PowerShell logo.
import Icon from './Icon.astro';
import PsLogo from './PsLogo.astro';

interface Props {
  command: string;
  shell?: 'powershell' | 'wsl';
}

const { command, shell = 'powershell' } = Astro.props;
const shellLabel = shell === 'powershell' ? 'PowerShell' : 'WSL 터미널';
const promptChar = shell === 'powershell' ? '>' : '$';
---

<figure class="command" data-shell={shell}>
  <figcaption>
    <span class="shell-chip">
      {shell === 'powershell' ? <PsLogo size={15} /> : <Icon name="terminal" size={13} />}
      {shellLabel}
    </span>
    <button type="button" data-copy={command} aria-label="Copy command" title="복사">
      <span class="ic-copy"><Icon name="copy" size={15} /></span>
      <span class="ic-check"><Icon name="check" size={15} /></span>
    </button>
  </figcaption>
  <pre><span class="prompt">{promptChar}</span> <code>{command}</code></pre>
</figure>

<style>
  .command {
    margin: 1.1rem 0;
    border-radius: 12px;
    overflow: hidden;
    background: #18181b;
    border: 1px solid #27272a;
    box-shadow: 0 4px 14px rgb(0 0 0 / 0.12);
  }

  figcaption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.45rem 0.7rem 0.45rem 0.9rem;
    border-bottom: 1px solid #27272a;
  }

  .shell-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #93c5fd;
  }

  .command[data-shell='wsl'] .shell-chip {
    color: #fdba74;
  }

  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: #a1a1aa;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }

  button:hover {
    background: #27272a;
    color: #e4e4e7;
  }

  button .ic-check {
    display: none;
    color: #4ade80;
  }

  button.copied .ic-copy {
    display: none;
  }

  button.copied .ic-check {
    display: inline-flex;
  }

  .ic-copy,
  .ic-check {
    display: inline-flex;
  }

  pre {
    margin: 0;
    padding: 0.85rem 0.95rem;
    overflow-x: auto;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .prompt {
    color: #4ade80;
    user-select: none;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    color: #e4e4e7;
  }
</style>

<script>
  // Copy the command text; swap to a check icon briefly as feedback.
  document.querySelectorAll<HTMLButtonElement>('button[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      await navigator.clipboard.writeText(button.dataset.copy ?? '');
      button.classList.add('copied');
      setTimeout(() => button.classList.remove('copied'), 1500);
    });
  });
</script>
