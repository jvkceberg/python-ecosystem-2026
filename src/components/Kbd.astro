---
// Physical-looking keycap. `win` and `enter` render with a glyph icon.
interface Props {
  k: string;
}

const { k } = Astro.props;
const key = k.toLowerCase();
const isWin = key === 'win';
const isEnter = key === 'enter';
---

<kbd class="keycap">
  {
    isWin && (
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <rect x="3" y="3" width="8.5" height="8.5" rx="0.5" />
        <rect x="12.5" y="3" width="8.5" height="8.5" rx="0.5" />
        <rect x="3" y="12.5" width="8.5" height="8.5" rx="0.5" />
        <rect x="12.5" y="12.5" width="8.5" height="8.5" rx="0.5" />
      </svg>
    )
  }
  {
    isEnter && (
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="9 10 4 15 9 20" />
        <path d="M20 4v7a4 4 0 0 1-4 4H4" />
      </svg>
    )
  }
  <span>{isWin ? '윈도우' : isEnter ? 'Enter' : k}</span>
</kbd>

<style>
  .keycap {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    vertical-align: baseline;
    padding: 0.1em 0.5em;
    min-width: 1.7em;
    justify-content: center;
    font-family: inherit;
    font-size: 0.82em;
    font-weight: 600;
    color: var(--ink);
    background: var(--key-bg);
    border: 1px solid var(--key-border);
    border-bottom-width: 3px;
    border-radius: 7px;
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.06);
    white-space: nowrap;
  }

  svg {
    flex-shrink: 0;
  }
</style>
